# ── Frontend (Vite — these values end up in the public bundle; public keys only) ──
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ── Server-side ONLY (Supabase Edge Function secrets — never read by the frontend) ──
# Set via: supabase secrets set OPENAI_API_KEY=...   (Masterplan §19 Security rules)
OPENAI_API_KEY=server_side_only_do_not_use_in_frontend
