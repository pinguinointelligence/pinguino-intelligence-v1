# ── Frontend (Vite — these values ship in the PUBLIC bundle; public keys only) ──
# Copy this file to `.env.local` (gitignored — NEVER commit it) and fill in your
# Supabase project values. The app builds and runs WITHOUT these set — auth simply
# reports as unavailable. NEVER put the Supabase service_role key in the frontend.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Sentry error monitoring (OPTIONAL). A Sentry DSN is public by design (ingest-only).
# Leave empty for local development — monitoring stays disabled and the console sink
# keeps working. On Vercel set this exact variable name with the project DSN.
VITE_SENTRY_DSN=

# ── Server-side ONLY (Supabase Edge Function secrets — never read by the frontend) ──
# Set via: supabase secrets set <NAME>=...  (Masterplan §19). Not used in Phase 2A.
# OPENAI_API_KEY=server_side_only_do_not_use_in_frontend
